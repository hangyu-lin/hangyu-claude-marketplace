{
  "name": "git-readonly",
  "description": "Git read-only — status, diff, log, show, blame, branch listing. No push, reset, clean, or other destructive operations.",
  "permissions": {
    "allow": [
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git blame *)",
      "Bash(git branch *)",
      "Bash(git tag *)",
      "Bash(git ls-files *)",
      "Bash(git ls-tree *)",
      "Bash(git rev-parse *)",
      "Bash(git remote -v *)",
      "Bash(git remote show *)",
      "Bash(git config --get *)",
      "Bash(git config --list *)",
      "Bash(git fetch *)"
    ]
  }
}
