{
  "name": "git",
  "description": "Git version control — all operations including destructive ones (reset, clean, push --force). Use git-readonly for a safer subset.",
  "permissions": {
    "allow": [
      "Bash(git add *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git commit *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git pull *)",
      "Bash(git push *)",
      "Bash(git fetch *)",
      "Bash(git stash *)",
      "Bash(git show *)",
      "Bash(git blame *)",
      "Bash(git tag *)",
      "Bash(git cherry-pick *)",
      "Bash(git reset *)",
      "Bash(git restore *)",
      "Bash(git remote *)",
      "Bash(git submodule *)",
      "Bash(git ls-files *)",
      "Bash(git ls-tree *)",
      "Bash(git rev-parse *)",
      "Bash(git config *)",
      "Bash(git clone *)",
      "Bash(git init *)"
    ]
  }
}
